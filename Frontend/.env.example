# Copy to .env.local for local dev, or set these in the Vercel dashboard.
# All NEXT_PUBLIC_* vars are exposed to the browser.

# Backend API (already has a built-in production fallback — optional)
NEXT_PUBLIC_API_URL=https://api.illusiodesigns.agency/api
NEXT_PUBLIC_IMAGE_URL=https://api.illusiodesigns.agency

# Canonical site URL — used for sitemap.xml, robots.txt and OG tags
NEXT_PUBLIC_SITE_URL=https://illusiodesigns.agency

# Analytics — leave blank to disable. Analytics only load after cookie consent.
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel ID, e.g. 1234567890123456
NEXT_PUBLIC_FB_PIXEL_ID=
